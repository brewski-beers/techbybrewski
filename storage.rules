rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Site assets: admins upload, public reads
    match /site/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Client files: admin full access, client can read/write their own (25MB cap)
    match /clients/{clientId}/{allPaths=**} {
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == clientId);
      allow write: if isAdmin()
        || (request.auth != null && request.auth.uid == clientId
          && request.resource.size < 25 * 1024 * 1024);
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
