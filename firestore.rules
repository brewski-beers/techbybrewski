rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requesting user is an admin
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Helper: check if the requesting user is a client
    function isClient() {
      return request.auth != null && request.auth.token.client == true;
    }

    // Helper: check if the requesting user is the owner or an admin
    function isOwnerOrAdmin(clientId) {
      return isAdmin() || (isClient() && request.auth.uid == clientId);
    }

    // ---- Site Settings ----
    match /siteSettings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---- Services ----
    match /services/{serviceId} {
      allow read: if resource.data.isPublished == true || isAdmin();
      allow write: if isAdmin();
    }

    // ---- Case Studies ----
    match /caseStudies/{caseId} {
      allow read: if resource.data.isPublished == true || isAdmin();
      allow write: if isAdmin();
    }

    // ---- Testimonials ----
    match /testimonials/{id} {
      allow read: if resource.data.isPublished == true || isAdmin();
      allow write: if isAdmin();
    }

    // ---- FAQs ----
    match /faqs/{id} {
      allow read: if resource.data.isPublished == true || isAdmin();
      allow write: if isAdmin();
    }

    // ---- Blog Posts ----
    match /blogPosts/{id} {
      allow read: if resource.data.isPublished == true || isAdmin();
      allow write: if isAdmin();
    }

    // ---- Contact Submissions ----
    // Anyone can create (public contact form); only admins can read
    match /contactSubmissions/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // ---- Activity Log ----
    // Admins can write and read; no public access
    match /activityLog/{id} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // ---- Clients (portal) ----
    match /clients/{clientId} {
      allow read, write: if isAdmin();
      allow read: if isClient() && request.auth.uid == clientId;
    }

    match /clients/{clientId}/contracts/{docId} {
      allow read, write: if isAdmin();
      allow read, create: if isOwnerOrAdmin(clientId);
    }

    match /clients/{clientId}/deliverables/{docId} {
      allow read, write: if isAdmin();
      allow read, create: if isOwnerOrAdmin(clientId);
    }

    match /clients/{clientId}/assets/{docId} {
      allow read, write: if isAdmin();
      allow read, create: if isOwnerOrAdmin(clientId);
    }

    match /clients/{clientId}/files/{docId} {
      allow read, write: if isAdmin();
      allow read, create: if isOwnerOrAdmin(clientId);
    }

    match /clients/{clientId}/messages/{msgId} {
      allow read, write: if isAdmin();
      allow read, create: if isOwnerOrAdmin(clientId);
    }

    match /clients/{clientId}/invoices/{invId} {
      allow read, write: if isAdmin();
      allow read: if isOwnerOrAdmin(clientId);
    }

    // ---- Deny everything else ----
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
